<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/header"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/btn_request_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_request_permission" />

        <Button
            android:id="@+id/btn_post_alpha_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_post_alpha_now" />

        <Button
            android:id="@+id/btn_post_beta_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_post_beta_now" />

        <Button
            android:id="@+id/btn_post_alpha_delayed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_post_alpha_delayed" />

        <Button
            android:id="@+id/btn_post_beta_delayed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_post_beta_delayed" />

        <Button
            android:id="@+id/btn_open_alpha_direct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_alpha_direct" />

        <Button
            android:id="@+id/btn_open_beta_direct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_beta_direct" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingTop="24dp" />
    </LinearLayout>
</ScrollView>
